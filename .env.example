# ===== Firecrawl (sua VPS) =====
FIRECRAWL_BASE_URL=https://automate-firecrawl.hr91bv.easypanel.host
# Se sua instancia self-hosted exigir chave, preencha. Se nao, deixe vazio.
FIRECRAWL_API_KEY=

# ===== MiniMax =====
MINIMAX_API_KEY=coloque_sua_chave_aqui
# Endpoint internacional (api.minimax.io) ou .chat conforme sua conta.
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-Text-01
# Algumas contas exigem GroupId. Se a sua nao usa, deixe vazio.
MINIMAX_GROUP_ID=

# ===== Chatwoot (opcional - para salvar os leads) =====
# Ex: https://app.chatwoot.com  ou  https://seu-chatwoot.dominio.com
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=

# ===== Negocio / oferta (personaliza a abordagem gerada) =====
AGENCY_OFFER=gestao de trafego pago, anuncios online (Google e Meta) e presenca digital
DEFAULT_NICHE=imobiliaria

# ===== Ajustes =====
DB_PATH=data/leads.db
REQUEST_TIMEOUT=90
RATE_LIMIT_SECONDS=1.5
